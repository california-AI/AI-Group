# ============================================================
# AI-Group Member Profiles - Environment Configuration
# Copy this file to .env and update values as needed.
# ============================================================

# --- Data version ---
# Bump this string whenever DEFAULT_MEMBERS or DEFAULT_PRODUCTS change
# so that browsers clear their localStorage cache and pick up fresh data.
DATA_VERSION=2026-05-11-members-251-v4-real-skillmatch

# --- Member count (informational) ---
MEMBER_COUNT=251

# --- localStorage keys ---
STORAGE_KEY=wechat_group_profiles
PRODUCTS_KEY=wechat_group_products
LIKES_KEY=wechat_product_likes
WALL_KEY=wechat_wall_posts
WALL_LIKES_KEY=wechat_wall_likes
WALL_FAVS_KEY=wechat_wall_favs

# --- Static-site server (used by docker-compose) ---
SERVE_PORT=8080

# --- Member-profile JSON path (used by Python embed scripts) ---
MEMBERS_JSON_PATH=./extracted_members.json

# --- Group skills JSON path ---
GROUP_SKILLS_JSON_PATH=./group_skills.json

# --- Encrypted page password (leave blank to skip encrypted build) ---
# ENCRYPTION_PASSWORD=
